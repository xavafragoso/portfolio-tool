# ─── Configuración de entorno — copiar a .env y completar ─────────────────────
# Clave de Google Gemini (google-genai). Usada en la SIGUIENTE fase
# (análisis fundamental / noticias). No se usa todavía en los módulos
# analíticos portados.
GEMINI_API_KEY=tu_api_key_aqui

# Capital base / NAV por defecto para el pipeline (USD).
NAV_USD=137723.85

# Tasa libre de riesgo anual por defecto (decimal, ej. 0.0525 = 5.25%).
RF_ANUAL=0.0525
